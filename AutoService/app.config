<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <!-- Подключение через Windows аутентификацию (Integrated Security) -->
    <add name="AutoServiceWinAuth"
         connectionString="Server=localhost\SQLEXPRESS;Database=AutoServiceDB;Integrated Security=true;TrustServerCertificate=true;"
         providerName="System.Data.SqlClient" />

    <!-- Подключение через логин и пароль SQL Server -->
    <add name="AutoServiceSqlAuth"
         connectionString="Server=localhost\SQLEXPRESS;Database=AutoServiceDB;User Id={0};Password={1};TrustServerCertificate=true;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <!-- Таймаут неактивности в минутах -->
    <add key="InactivityTimeoutMinutes" value="15" />
  </appSettings>
</configuration>
